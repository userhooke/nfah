{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "nfah",
  "scopeName": "source.nfah",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nfah",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nfah",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nfah",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nfah",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.nfah",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.nfah",
          "match": "\\b(if|then|else)\\b"
        },
        {
          "name": "keyword.control.return.nfah",
          "match": "\\breturn\\b"
        },
        {
          "name": "constant.language.boolean.nfah",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.nfah",
          "match": "==>|=>"
        },
        {
          "name": "keyword.operator.assignment.nfah",
          "match": "="
        },
        {
          "name": "punctuation.accessor.nfah",
          "match": "\\."
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.nfah",
          "match": "(?<=\\.)[A-Za-z][A-Za-z0-9_?-]*"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.identifier.nfah",
          "match": "\\b[A-Za-z][A-Za-z0-9_?-]*\\b"
        }
      ]
    }
  }
}
